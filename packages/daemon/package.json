{
  "name": "@homefleet/daemon",
  "version": "0.0.0",
  "description": "homefleetd — the HomeFleet per-machine daemon (MCP front, node service, discovery, dispatch)",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "bin": {
    "homefleet": "./dist/bin/homefleet.js",
    "homefleet-mcp-stdio": "./dist/bin/homefleet-mcp-stdio.js",
    "homefleetd": "./dist/bin/homefleetd.js"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@homefleet/executors": "workspace:*",
    "@homefleet/protocol": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@peculiar/x509": "^2.0.0",
    "bonjour-service": "^1.4.1",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.4.3"
  }
}
